# ─── AITechPulse Environment Configuration ───
# Copy this file to .env and update values

# Data source URL (SharePoint / Teams shared folder link)
VITE_DATA_URL=https://your-company.sharepoint.com/sites/your-team/Shared%20Documents/General/tech-landscape.xlsx

# App display settings
VITE_APP_TITLE=AITechPulse
VITE_TEAM_NAME=Platform Engineering

# Feature flags
VITE_ENABLE_UPLOAD=true
VITE_ENABLE_PRINT=true
VITE_ENABLE_SEARCH=true

# Auto-refresh interval in minutes (0 = disabled)
VITE_REFRESH_INTERVAL=30
